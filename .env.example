# Application
APP_ENV=development
API_BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/po_email

# Redis (job queue)
REDIS_URL=redis://localhost:6379/0

# Blob storage (local path for dev)
BLOB_STORAGE_PATH=./data/attachments

# Microsoft Graph / Azure AD
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_REDIRECT_URI=http://localhost:8000/auth/callback
GRAPH_SCOPES=Mail.Read offline_access

# Token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# Classifier
CLASSIFIER_MODEL_PATH=./models/classifier
CLASSIFIER_MODEL_VERSION=1.0.0

# Extraction
EXTRACTION_RULES_PATH=./extraction/rules
EXTRACTOR_VERSION=1.0.0
OCR_ENABLED=true
